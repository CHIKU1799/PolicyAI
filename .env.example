# ==========================================================
# PolicyAI — Environment variables
# Copy this file to `.env` and fill in secrets before running.
# ==========================================================

# --- Postgres (consumed by docker-compose.yml and the app) ---
POSTGRES_USER=policyai
POSTGRES_PASSWORD=policyai
POSTGRES_DB=policyai
POSTGRES_PORT=5432
# Full async DSN used by the SQLAlchemy + asyncpg stack.
DATABASE_URL=postgresql+asyncpg://policyai:policyai@localhost:5432/policyai

# --- Anthropic Claude API ---
# Provision a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Extraction model (see PROJECT_CONTEXT.md — locked to claude-sonnet-4).
ANTHROPIC_MODEL=claude-sonnet-4

# --- Scraping ---
# Comma-separated sources to ingest. Supported: rbi,sebi
SCRAPER_SOURCES=rbi,sebi
# Months of history to backfill on the first run (MVP target: 6).
SCRAPER_BACKFILL_MONTHS=6

# --- Prefect orchestration ---
# Leave blank for local ephemeral mode. Set to a Cloud URL when deploying.
PREFECT_API_URL=
PREFECT_API_KEY=

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
# CORS origin allowed for the Next.js frontend during dev.
FRONTEND_ORIGIN=http://localhost:3000

# --- Next.js frontend ---
# Base URL the frontend uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:8000
