# ==========================================================
# PolicyAI — Environment variables
# Copy this file to `.env` and fill in secrets before running.
#
# Cloud-first: nothing of substance lives on local disk. Postgres + Storage +
# Realtime are Supabase; the worker/crawler run on Render; the UI on Vercel.
# ==========================================================

# --- Supabase Postgres (the knowledge graph DB) ---
# Project settings -> Database -> Connection string -> URI.
# Use the SESSION pooler (port 5432) for migrations and the app. The driver is
# made PgBouncer-safe in db.py (statement_cache_size=0), so the transaction
# pooler (6543) also works if you prefer it.
# Convert the scheme to `postgresql+asyncpg://` for the SQLAlchemy stack.
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Supabase API (Storage uploads, Realtime, server-side writes) ---
# Project settings -> API.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
# Service-role key: SERVER-SIDE ONLY (worker). Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket holding uploaded company policy documents.
SUPABASE_KB_BUCKET=company-documents

# --- Object storage backend (document lake) ---
# supabase (default) OR r2 (Cloudflare R2 — S3-compatible, zero egress).
# For r2: create a bucket + API token in Cloudflare, then `uv add aioboto3`.
STORAGE_BACKEND=supabase
R2_ENDPOINT=                 # https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- LLM provider ---
# anthropic (default, paid) OR openai_compatible (open-source models, free).
LLM_PROVIDER=anthropic

# Anthropic (when LLM_PROVIDER=anthropic). Key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_EXTRACTION=claude-sonnet-4-6
ANTHROPIC_MODEL_MAPPING=claude-opus-4-8

# Open-source / hosted models (when LLM_PROVIDER=openai_compatible). Any
# OpenAI-compatible endpoint works. Use `make llm-<provider>` to switch presets;
# each provider keeps its key in its own slot below and the switcher copies the
# active one into OPENAI_API_KEY.
#   make llm-groq        Groq llama-3.3-70b (12k tokens/request, ~100k/day free)
#   make llm-cerebras    Cerebras llama-3.3-70b (60k TPM, ~1M tokens/day free)
#   make llm-gemini      Google gemini-2.5-flash via OpenAI-compatible endpoint
#   make llm-mistral     Mistral small (generous free experiment tier)
#   make llm-openrouter  OpenRouter free model pool
#   make llm-claude      back to Anthropic
# Ollama (local, fully offline) is manual:
#     OPENAI_BASE_URL=http://localhost:11434/v1
#     OPENAI_API_KEY=ollama       LLM_MODEL=llama3.1
OPENAI_BASE_URL=https://router.huggingface.co/v1
OPENAI_API_KEY=
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Per-request token ceiling the gateway enforces (input + max_tokens); the
# switcher sets it per provider (Groq 12000, Cerebras 60000, others 0 = off).
OPENAI_TPM_LIMIT=0
# Provider key slots (create free keys at each console):
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# --- Reranker (improves retrieval quality; Claude still does all reasoning) ---
# Reorders vector + full-text candidates before the Ask agent / obligation mapping
# reason over them, improving precision. Defaults to Cohere (managed, multilingual,
# no infra) since COHERE_API_KEY is already set; set `off` to disable.
#   cohere : Cohere /rerank, rerank-v3.5 (uses COHERE_API_KEY)
#   local  : in-process BAAI/bge-reranker-v2-m3 (needs `uv add sentence-transformers`)
#   hf     : a TEI /rerank endpoint (set RERANK_ENDPOINT + HF_API_TOKEN)
RERANK_PROVIDER=cohere
RERANK_ENDPOINT=

# --- Embeddings (1024-dim to match EMBEDDING_DIM) ---
# Pick ONE provider. If HuggingFace is giving you trouble, use `local` (most
# robust — no API) or a managed key (`voyage`/`cohere`).
#   local  : runs bge-m3 in-process. Needs `uv add sentence-transformers` (~2GB).
#   hf     : dedicated endpoint (HF_EMBEDDING_ENDPOINT) OR, if blank + token set,
#            the HF serverless API (free, but cold-starts / can be unavailable).
#   voyage : voyage-3, one key, very reliable.
#   cohere : embed-multilingual-v3, one key.
EMBEDDING_PROVIDER=local
HF_EMBEDDING_ENDPOINT=
HF_API_TOKEN=
VOYAGE_API_KEY=
COHERE_API_KEY=

# --- gbrain / hermes enrichment (optional adapter) ---
# Base URL of the gbrain service (Render-hosted). If blank, the platform runs
# docs-only: profiles derive from uploads, task owners are left unassigned.
GBRAIN_BASE_URL=
GBRAIN_API_KEY=

# --- Email alerts via Resend (optional) ---
# No-op unless both RESEND_API_KEY and ALERT_EMAIL_TO are set.
RESEND_API_KEY=
ALERT_EMAIL_TO=                       # comma-separated recipients
# Default sender 'onboarding@resend.dev' only delivers to your own Resend account
# email; set a verified-domain sender for real recipients.
ALERT_EMAIL_FROM=PolicyAI <onboarding@resend.dev>
# Which alert kinds trigger email (new_regulation excluded to avoid backfill spam).
ALERT_EMAIL_KINDS=new_obligation,scan_failed

# --- Scraping ---
# Months of history to backfill on the first run (MVP target: 6).
SCRAPER_BACKFILL_MONTHS=6
# Polite delay between requests to a regulator site, in seconds.
SCRAPER_REQUEST_DELAY=2.0

# --- Worker (FastAPI on Render) ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated CORS origins allowed to call the worker (the Vercel domain
# plus localhost for dev).
FRONTEND_ORIGINS=http://localhost:3000
# Shared secret guarding internal endpoints (pg_net trigger -> /internal/*).
INTERNAL_API_SECRET=

# --- Next.js frontend (Vercel) ---
# These three are the only vars the browser/SSR needs.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Base URL the frontend uses to reach the Render worker.
NEXT_PUBLIC_API_URL=http://localhost:8000
